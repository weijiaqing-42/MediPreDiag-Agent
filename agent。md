4.3 条件边（Conditional Edges）
Python

# Supervisor 路由逻辑（伪代码）
def route_by_intent(state: MediState) -> str:
    intent = state["intent"]
    if state["interrupt_flag"]:
        return "interrupt_handler"
    if state["timeout_flag"]:
        return "interrupt_handler"
    if intent == "emergency":
        return "severity_evaluator"  # 直接跳到严重度评估
    if intent == "symptom_query":
        if state["image_url"]:
            return "image_analyzer"
        return "symptom_extractor"
    if intent == "drug_query":
        return "drug_qa_agent"
    if intent == "location_search":
        return "location_recommender"
    return "response_synthesizer"  # 闲聊等直接合成
