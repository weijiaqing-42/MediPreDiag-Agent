5.4 高德地图 POI 周边搜索（MCP Tool）
17
 周边搜索 API 接口格式为：`https://restapi.amap.com/v3/place/around?key=<key>&location=经度,纬度&radius=搜索半径&types=POI类型`
Python

# MCP Tool 封装
class AmapPOISearchTool:
    """
    严重度 → 搜索策略映射：
    - mild   → types=010901(药店)  radius=1000m
    - moderate → types=090100(综合医院) radius=3000m
    - severe → types=090101(急救中心)+090100  radius=5000m
    """
    POI_TYPES = {
        "pharmacy":  "010901",
        "hospital":  "090100",
        "emergency": "090101",
        "clinic":    "090200",
    }

    def search(self, location: tuple, severity: str) -> list:
        # location = (lng, lat)  来自用户前端上报 或 IP定位
        endpoint = "https://restapi.amap.com/v3/place/around"
        strategy = self._get_strategy(severity)
        params = {
            "key":        AMAP_API_KEY,
            "location":   f"{location[0]},{location[1]}",
            "radius":     strategy["radius"],
            "types":      strategy["types"],
            "offset":     5,          # 返回5个结果
            "extensions": "all",      # 返回详情
            "sortrule":   "distance", # 按距离排序
        }
        resp = requests.get(endpoint, params=params, timeout=5)
        return self._parse_poi(resp.json())
5.5 业务中断/回滚/超时/失败处理机制
Python

class InterruptHandler:
    """
    触发条件：
    1. 超时: 任意 Agent 节点超过 timeout_threshold（默认15s）
    2. 工具失败: 高德API/Milvus异常，retry_count > MAX_RETRY（3次）
    3. 主动中断: 用户发送"取消"/"重新开始"等关键词
    4. 置信度过低: 严重程度评估置信度 < 0.5 → 要求补充信息
    """

    def handle(self, state: MediState) -> MediState:
        reason = self._detect_reason(state)

        if reason == "user_cancel":
            # 清除 Redis 状态，返回欢迎语
            return self._clean_rollback(state)

        elif reason == "tool_timeout":
            # 记录失败节点，降级到无地图模式继续
            state["nearby_places"] = []
            state["final_response"] += "\n（地点服务暂时不可用，建议自行搜索附近医院）"
            return state

        elif reason == "low_confidence":
            # 回滚到 symptom_extractor，生成追问
            state["rollback_target"] = "symptom_extractor"
            state["final_response"] = self._gen_followup_question(state)
            return state

        elif reason == "api_error":
            # 记录错误日志，返回降级回复
            logger.error(f"API error in session {state['session_id']}")
            return self._degraded_response(state)
