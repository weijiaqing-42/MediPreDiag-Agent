from typing import TypedDict, Literal, Optional, List
from langgraph.graph import StateGraph

class MediState(TypedDict):
    # 用户输入
    user_id: str
    session_id: str
    user_message: str
    image_url: Optional[str]
    user_location: Optional[tuple]  # (lng, lat)

    # 意图与流程控制
    intent: Literal[
        "symptom_query", "drug_query",
        "location_search", "chitchat",
        "emergency", "unknown"
    ]
    interrupt_flag: bool       # 业务中断标志
    retry_count: int           # 重试计数
    timeout_flag: bool         # 超时标志
    rollback_target: Optional[str]  # 回滚目标节点名

    # 分析结果
    extracted_symptoms: List[str]
    possible_diseases: List[dict]   # [{name, confidence, severity}]
    severity_level: Literal["mild", "moderate", "severe", "unknown"]
    rag_context: str            # 检索到的知识库上下文

    # 输出
    medical_advice: str
    nearby_places: List[dict]   # 高德返回的 POI 列表
    drug_info: str
    final_response: str

    # 记忆
    short_term_history: List[dict]   # 来自 Redis
    long_term_summary: str           # 来自 Milvus
